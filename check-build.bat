@echo off
powershell -Command "$out = ''; try { $r = Invoke-WebRequest -Uri 'https://zibendao.vercel.app/_next/static/chunks/app/layout.js' -UseBasicParsing -MaximumRedirection 0 -ErrorAction Stop; $out = 'STATUS=' + $r.StatusCode + ' size=' + $r.Content.Length } catch { $err = $_.Exception.Response; if ($err) { $out = 'REDIRECT=' + [int]$err.StatusCode } else { $out = 'ERROR=' + $_.Exception.Message } }; Write-Host $out; $out2 = ''; try { $r2 = Invoke-WebRequest -Uri 'https://zibendao.vercel.app/api/auth/providers' -UseBasicParsing -MaximumRedirection 5 -ErrorAction Stop; $out2 = 'PROVIDERS_STATUS=' + $r2.StatusCode + ' body=' + $r2.Content.Substring(0, [Math]::Min(200, $r2.Content.Length)) } catch { $out2 = 'PROVIDERS_ERR=' + $_.Exception.Message }; Write-Host $out2; ($out + '^n' + $out2) | Out-File 'C:\Users\Dell\Desktop\build-result.txt' -Encoding utf8"
pause
