generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  hashedPassword    String?
  role              Role               @default(FREE_MEMBER)
  studentLevel      Int?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  image             String?
  emailVerified     DateTime?
  phone             String?
  company           String?
  position          String?
  city              String?
  bio               String?
  verifyToken       String?            @unique
  verifyTokenExpiry DateTime?
  studentAccountNo  String?            @unique
  // Gamification
  xp                Int                @default(0)
  capitalLevel      Int                @default(1)
  streak            Int                @default(0)
  lastActiveAt      DateTime?
  badges            Json?
  accounts          Account[]
  toolAccess        ClientToolAccess[]
  documents         Document[]
  progress          LessonProgress[]
  onlineProgress    OnlineLessonProgress[]
  payments          Payment[]
  sessions          Session[]
  offlineAccount    OfflineStudentAccount?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Module {
  id            String   @id @default(cuid())
  title         String
  description   String
  order         Int
  requiredLevel Int
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  lessons       Lesson[]
}

model Lesson {
  id       String           @id @default(cuid())
  moduleId String
  title    String
  type     LessonType
  content  Json
  order    Int
  points   Int              @default(10)
  module   Module           @relation(fields: [moduleId], references: [id])
  progress LessonProgress[]
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  score       Int?
  completedAt DateTime?
  lesson      Lesson    @relation(fields: [lessonId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Tool {
  id            String             @id @default(cuid())
  name          String
  slug          String             @unique
  description   String
  requiredLevel Int
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  clientAccess  ClientToolAccess[]
}

model ClientToolAccess {
  userId    String
  toolId    String
  grantedAt DateTime @default(now())
  tool      Tool     @relation(fields: [toolId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, toolId])
}

model Document {
  id            String    @id @default(cuid())
  userId        String
  title         String
  content       Json
  pdfUrl        String?
  status        DocStatus @default(DRAFT)
  signatureData String?
  signedAt      DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String    @id @default(cuid())
  userId    String
  amount    Float
  currency  String    @default("MYR")
  status    PayStatus @default(PENDING)
  provider  String
  metadata  Json?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OfflineStudentAccount {
  id           String        @id @default(cuid())
  accountNo    String        @unique
  phone        String
  holderName   String
  course       OfflineCourse
  linkedUserId String?       @unique
  linkedUser   User?         @relation(fields: [linkedUserId], references: [id])
  createdAt    DateTime      @default(now())
}

model ContractTemplate {
  id        String   @id @default(cuid())
  title     String
  content   String
  variables Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ZIBENTONG_GRAD
  QIDONG_GRAD
  ZIBENDAO_GRAD
  ONLINE_STUDENT
  ENTERPRISE_CLIENT
  FREE_MEMBER
}

enum OfflineCourse {
  CAPITAL_MAP
  CAPITAL_CODE
  CAPITAL_DAO
}

enum LessonType {
  VIDEO
  READING
  QUIZ
  EXERCISE
}

// ─── Online Immersive Course System ────────────────────────────────────────

model OnlineModule {
  id          String               @id @default(cuid())
  slug        String               @unique
  order       Int
  xpReward    Int                  @default(100)
  isPublished Boolean              @default(true)
  createdAt   DateTime             @default(now())
  lessons     OnlineLesson[]
}

model OnlineLesson {
  id          String               @id @default(cuid())
  moduleId    String
  slug        String               @unique
  order       Int
  type        OnlineLessonType     @default(STORY)
  xpReward    Int                  @default(20)
  createdAt   DateTime             @default(now())
  module      OnlineModule         @relation(fields: [moduleId], references: [id])
  progress    OnlineLessonProgress[]
}

model OnlineLessonProgress {
  id          String       @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean      @default(false)
  score       Int?
  completedAt DateTime?
  lesson      OnlineLesson @relation(fields: [lessonId], references: [id])
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

enum OnlineLessonType {
  STORY
  QUIZ
  SIMULATION
  REFLECTION
}

enum DocStatus {
  DRAFT
  SENT
  SIGNED
}

enum PayStatus {
  PENDING
  SUCCESS
  FAILED
}
